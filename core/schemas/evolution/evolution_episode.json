{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-os.dev/schemas/evolution-v1/evolution_episode.json",
  "title": "Evolution v1 Episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "hypothesis",
    "mutation",
    "metrics_before",
    "metrics_after",
    "gate_result",
    "decision",
    "provenance",
    "version"
  ],
  "properties": {
    "episode_id": {"type": "string", "minLength": 1},
    "parent_episode_id": {"type": "string", "minLength": 1},
    "hypothesis": {"type": "string", "minLength": 1},
    "mutation": {"$ref": "mutation.json"},
    "suite_ref": {"type": "string", "minLength": 1},
    "metrics_before": {"$ref": "evaluation_report.json#/properties/metrics"},
    "metrics_after": {"$ref": "evaluation_report.json#/properties/metrics"},
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "reasons"],
      "properties": {
        "passed": {"type": "boolean"},
        "reasons": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "decision": {
      "type": "string",
      "enum": ["promoted", "rejected", "rolled_back"]
    },
    "rollback_ref": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captured_at", "captured_by", "confidence"],
      "properties": {
        "captured_at": {"type": "string", "format": "date-time"},
        "captured_by": {"type": "string", "minLength": 1},
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "version": {
      "type": "string",
      "const": "evolution-contract-v1"
    }
  }
}