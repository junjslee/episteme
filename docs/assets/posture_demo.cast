[0.000, "o", "   \u001b[31m03\u001b[0m \u001b[1mAnchoring\u001b[0m              \u001b[33m(a)\u001b[0m \"semantic\" in prompt anchored plan   \u001b[33m(c)\u001b[0m needs Disconfirmation\r\n"]
[0.000, "o", "   \u001b[31m05\u001b[0m \u001b[1mPlanning fallacy\u001b[0m       \u001b[33m(a)\u001b[0m no eval, no rollback cost, no ops   \u001b[33m(c)\u001b[0m inversion + margin of safety\r\n"]
[0.001, "o", "   \u001b[31m06\u001b[0m \u001b[1mOverconfidence\u001b[0m         \u001b[33m(a)\u001b[0m no pre-stated pivot condition       \u001b[33m(c)\u001b[0m Disconfirmation field\r\n\r\n"]
[1.610, "o", "\u001b[1m\u001b[36mв–җ EPISTEME В· posture on В· Reasoning Surface authored field-by-field\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[2mSame prompt. The posture refuses to answer the asked question until it reframes it.\u001b[0m\r\n"]
[0.811, "o", "\r\n"]
[0.000, "o", "  \u001b[1mCore Question (reframed вҖ” not the PM question):\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m\"Do we have evidence that keyword search is the load-bearing failure,\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m before committing 2 sprints to semantic search?\"\u001b[0m\r\n"]
[0.000, "o", "   \u001b[33m(a)\u001b[0m reframes the question            \u001b[33m(b)\u001b[0m fluent answer answered the wrong one\r\n   \u001b[33m(c)\u001b[0m counters 02 Question substitution\r\n\r\n"]
[0.813, "o", "  \u001b[1mUnknowns (classifiable, not hand-wavy):\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m В· What % of failed searches are typos vs stop-word vs content-missing\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m   vs discoverability-external vs genuine semantic gap?\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m В· Base rate: does BM25 actually lose to vectors at this scale/domain?\u001b[0m\r\n  \u001b[36m В· Current false-negative rate on a labelled gold set? (no gold set exists)\u001b[0m\r\n   \u001b[33m(a)\u001b[0m five distinct failure modes       \u001b[33m(b)\u001b[0m the fluent response lumped them as one\r\n"]
[0.000, "o", "   \u001b[33m(c)\u001b[0m counters 01 WYSIATI\r\n\r\n"]
[0.811, "o", "  \u001b[1mDisconfirmation (pre-committed pivot condition):\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m\"If query-log analysis shows over 50% of failed searches are true\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m semantic gaps, the semantic hypothesis survives and we build.\u001b[0m\r\n"]
[0.000, "o", "  \u001b[36m If under 30%, we do not.\"\u001b[0m\r\n"]
[0.000, "o", "   \u001b[33m(a)\u001b[0m pivot named before the work      \u001b[33m(b)\u001b[0m makes the plan falsifiable\r\n"]
