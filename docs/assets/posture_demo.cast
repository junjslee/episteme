[1.613, "o", "\u001b[1m\u001b[33mв”Җв”Җв”Җ  BEAT 3  В·  THE SPECIFICITY LADDER  в”Җв”Җв”Җ\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[2mThree disconfirmations, validated live against the Reasoning-Surface Guard.\u001b[0m\r\n"]
