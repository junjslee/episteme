[0.008, "o", "import httpx\r\n\r\nclass PaymentsClient:\r\n    def __init__(self, base_url: str, timeout: float = 10.0):\r\n        self.client = httpx.Client(base_url=base_url, timeout=timeout)\r\n\r\n    def charge(self, amount_cents: int, idempotency_key: str) -> dict:\r\n        r = self.client.post(\"/charge\", json={\"amount\": amount_cents},\r\n                              headers={\"Idempotency-Key\": idempotency_key})\r\n        r.raise_for_status()\r\n        return r.json()\r\n"]
[0.000, "o", "\u001b[90mEOF\r\n\u001b[0m"]
[0.860, "o", "  \u001b[2m\u001b[3m# PreToolUse В· framework query fires before the guard runs layer 2.\u001b[0m\r\n"]
