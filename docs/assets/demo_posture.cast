[0.000, "o", "  \u001b[1mrule\u001b[0m                          a constraint unchanged в‰Ґ 100 commits requires a\r\n                                 named reason for removal\r\n\r\n"]
[0.000, "o", "  write \u001b[1m.episteme/reasoning-surface.json\u001b[0m with:\r\n     В· knowns         вЂ” why the constraint was installed\r\n"]
[0.000, "o", "     В· unknowns       вЂ” evidence the constraint is now obsolete\r\n"]
[0.000, "o", "     В· assumptions    вЂ” regression coverage protecting removal\r\n"]
[0.001, "o", "     В· disconfirmation вЂ” observable that would prove removal unsafe\r\n     В· sync_plan      вЂ” downstream surfaces to update\r\n\r\n"]
[0.000, "o", "  \u001b[3mor\u001b[0m propose a non-removal resolution (wrap В· replace В· escalate)\r\n"]
